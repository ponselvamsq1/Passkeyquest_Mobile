MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1569782355}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fcf6f1575b53bed40a6e56d964c63f5f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  questionText: {fileID: 1013545554978838312}
  optionButtons:
  - {fileID: 8348829715328780037}
  - {fileID: 5488365385395265286}
  - {fileID: 5790111662646118119}
  - {fileID: 6834663699371956319}
  questions:
  - questionText: 'What is the first line of defense for your online accounts? '
    options:
    - 'a) Data encryption '
    - 'b) Network firewall  '
    - 'c) Strong password  '
    - 'd) Antivirus software '
    correctAnswerIndex: 2
    feedback: A strong password is the first layer of protection, making it harder
      for attackers to gain unauthorized access.
  - questionText: What is a common way hackers try to guess passwords?
    options:
    - 'a) Manually trying random passwords '
    - 'b) Brute-force attacks '
    - c) Social media analysis
    - 'd) Phishing emails '
    correctAnswerIndex: 1
    feedback: Brute-force attacks involve systematically trying many password combinations
      to gain access.
  - questionText: Which attack method involves tricking people into revealing their
      passwords through fake emails?
    options:
    - a) Brute force
    - 'b) Dictionary attack  '
    - 'c) Phishing  '
    - 'd) Credential stuffing '
    correctAnswerIndex: 2
    feedback: Phishing deceives users into providing passwords by pretending to be
      a trusted entity.
  - questionText: In online security, what does MFA stand for?
    options:
    - 'a) Multiple Factor Authentication  '
    - 'b) Main Factor Authentication  '
    - 'c) Multi-Function Access  '
    - 'd) Maximum Firewall Access '
    correctAnswerIndex: 0
    feedback: Multi-factor authentication (MFA) adds an extra security layer by requiring
      a second verification step.
  - questionText: Which of the following is NOT listed as a common type of second
      factor for MFA?
    options:
    - a) Something you know (like a PIN)
    - b) Something you have (like a smartphone)
    - 'c) Something you are (like a fingerprint)  '
    - 'd) Something you feel (like confidence) '
    correctAnswerIndex: 3
    feedback: "MFA relies on \"something you know,\" \"something you have,\" or \"something
      you are\"\u2014but not feelings like confidence"
  submitButton: {fileID: 474577287}
  feedbackText: {fileID: 950232593}
  feedbackFinalText: {fileID: 1758905549}
  correctpane: {fileID: 701015792}
  wrongpanel: {fileID: 1468704440}
  finalpanel: {fileID: 1155250952}
  quizfinsihpanel: {fileID: 107095269}
